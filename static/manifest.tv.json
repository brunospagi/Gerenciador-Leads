{
    "name": "Spagi TV Player",
    "short_name": "Spagi TV",
    "description": "Player de Vídeo e Notícias da Spagi Motors.",
    "start_url": "/tv-video/",
    "id": "/tv-video/",
    "scope": "/tv-video/",
    "display": "fullscreen", 
    "display_override": ["fullscreen", "standalone"],
    "background_color": "#000000",
    "theme_color": "#000000",
    "orientation": "landscape-primary",
    "lang": "pt-BR",
    "launch_handler": {
        "client_mode": "navigate-existing"
    },
    "file_handlers": [
        {
            "action": "/tv-video/",
            "name": "Abrir video na Spagi TV",
            "accept": {
                "video/mp4": [".mp4", ".m4v"],
                "video/webm": [".webm"],
                "video/ogg": [".ogv", ".ogg"]
            }
        }
    ],
    "icons": [
        {
            "src": "/static/images/logo-spagi-192x192.png",
            "type": "image/png",
            "sizes": "192x192"
        },
        {
            "src": "/static/images/logo-spagi-512x512.png",
            "type": "image/png",
            "sizes": "512x512"
        }
    ],
    "shortcuts": [
         {
            "name": "Abrir TV",
            "short_name": "TV",
            "description": "Abrir o player de vídeo da TV",
            "url": "/tv-video/",
            "icons": [{ "src": "/static/images/logo-spagi-192x192.png", "sizes": "192x192" }]
        }
    ]
}
