{
    "name": "Spagi TV Player",
    "short_name": "Spagi TV",
    "description": "Player de Vídeo e Notícias da Spagi Motors.",
    "start_url": "/tv-video/",
    "id": "/tv-video/",
    "scope": "/tv-video/",
    "display": "fullscreen", 
    "display_override": ["window-controls-overlay", "tabbed", "fullscreen", "standalone"],
    "tab_strip": {
        "home_tab": {
            "scope_patterns": [
                { "pathname": "/tv-video/" }
            ]
        },
        "new_tab_button": {
            "url": "/tv-video/"
        }
    },
    "background_color": "#000000",
    "theme_color": "#000000",
    "orientation": "landscape-primary",
    "lang": "pt-BR",
    "launch_handler": {
        "client_mode": "navigate-existing"
    },
    "file_handlers": [
        {
            "action": "/tv-video/",
            "name": "Abrir video na Spagi TV",
            "accept": {
                "video/mp4": [".mp4", ".m4v"],
                "video/webm": [".webm"],
                "video/ogg": [".ogv", ".ogg"]
            }
        }
    ],
    "protocol_handlers": [
        {
            "protocol": "web+spagitv",
            "url": "/tv-video/?source=%s",
            "title": "Abrir Spagi TV"
        }
    ],
    "share_target": {
        "action": "/tv-video/",
        "method": "GET",
        "enctype": "application/x-www-form-urlencoded",
        "params": {
            "title": "title",
            "text": "text",
            "url": "url"
        }
    },
    "edge_side_panel": {
        "preferred_width": 520
    },
    "widgets": [
        {
            "name": "Spagi TV Agora",
            "short_name": "TV Agora",
            "description": "Atalho rapido para abrir o player da Spagi TV.",
            "tag": "spagi-tv-now",
            "template": "spagi-tv-widget",
            "ms_ac_template": "/static/widgets/spagi-tv-template.json",
            "data": "/static/widgets/spagi-tv-data.json",
            "type": "application/json",
            "auth": false,
            "update": 86400,
            "multiple": false,
            "icons": [
                {
                    "src": "/static/images/logo-spagi-192x192.png",
                    "sizes": "192x192"
                }
            ],
            "screenshots": [
                {
                    "src": "/static/images/logo-spagi-512x512.png",
                    "sizes": "512x512",
                    "label": "Widget da Spagi TV"
                }
            ]
        }
    ],
    "icons": [
        {
            "src": "/static/images/logo-spagi-192x192.png",
            "type": "image/png",
            "sizes": "192x192"
        },
        {
            "src": "/static/images/logo-spagi-512x512.png",
            "type": "image/png",
            "sizes": "512x512"
        }
    ],
    "shortcuts": [
         {
            "name": "Abrir TV",
            "short_name": "TV",
            "description": "Abrir o player de vídeo da TV",
            "url": "/tv-video/",
            "icons": [{ "src": "/static/images/logo-spagi-192x192.png", "sizes": "192x192" }]
        }
    ]
}
