# Django Core Settings
# IMPORTANTE: Gere uma nova chave secreta para produção.
DJANGO_SECRET_KEY="django-insecure-example-key-change-me"
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=app.exemplo.local,www.app.exemplo.local
DJANGO_CSRF_TRUSTED_ORIGINS=https://app.exemplo.local,https://www.app.exemplo.local
DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_USE_X_FORWARDED_HOST=False
DJANGO_SECURE_HSTS_SECONDS=0
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=False
DJANGO_SECURE_HSTS_PRELOAD=False
# Opcional: sobrescrever CSP default
# DJANGO_CONTENT_SECURITY_POLICY=default-src 'self'; script-src 'self' 'unsafe-inline';
APP_BUILD_NUMBER=20260507.1
APP_BUILD_SHA=abc12345

# Cron interno do container (check_inactivity, check_overdue_clients).
# Se a aplicacao rodar com multiplas replicas, defina ENABLE_CRON=false em todas
# menos uma, para nao duplicar os jobs agendados e as notificacoes que eles disparam.
ENABLE_CRON=true

# Database Settings
# DB_ENGINE aceitos: postgres | sqlite
DB_ENGINE=postgres

# PostgreSQL (usado quando DB_ENGINE=postgres)
DB_NAME=app_exemplo
DB_USER=app_user
DB_PASSWORD="senha_ficticia_123"
DB_HOST=postgres
DB_PORT=5432

# SQLite (usado quando DB_ENGINE=sqlite)
SQLITE_PATH=db.sqlite3

# MinIO Storage Settings
MINIO_EXTERNAL_ENDPOINT="s3.exemplo.local"
MINIO_STORAGE_ENDPOINT="s3.exemplo.local"
MINIO_STORAGE_ACCESS_KEY="ACCESS_KEY_EXEMPLO"
MINIO_STORAGE_SECRET_KEY="SECRET_KEY_EXEMPLO"
MINIO_STORAGE_USE_HTTPS=True
MINIO_STORAGE_MEDIA_BUCKET_NAME="app-exemplo-media"

# Django Superuser (Opcional, usado por alguns scripts de inicialização)
DJANGO_SUPERUSER_PASSWORD=admin123

# Gemini API Key
GEMINI_API_KEY="GEMINI_KEY_EXEMPLO"
# Modelo Gemini com suporte a geracao/edicao de imagem, usado pelo marketing_ia
GEMINI_IMAGE_MODEL="gemini-2.5-flash-image"

# Google Maps API Key (Necessária para a API Weather)
GOOGLE_MAPS_API_KEY="GOOGLE_MAPS_KEY_EXEMPLO"

# NewsData.io API Key (Usada para o ticker de notícias)
NEWSDATA_API_KEY="NEWSDATA_KEY_EXEMPLO"

# Web Push Notifications (VAPID Keys)
VAPID_PUBLIC_KEY="VAPID_PUBLIC_KEY_EXEMPLO"
VAPID_PRIVATE_KEY="VAPID_PRIVATE_KEY_EXEMPLO"
VAPID_ADMIN_EMAIL="admin@exemplo.local"

# OpenID Connect (OIDC) Settings for Authentik
OIDC_RP_CLIENT_ID=oidc_client_id_exemplo
OIDC_RP_CLIENT_SECRET=oidc_client_secret_exemplo
OIDC_OP_AUTHORIZATION_ENDPOINT=https://auth.exemplo.local/application/o/authorize/
OIDC_OP_TOKEN_ENDPOINT=https://auth.exemplo.local/application/o/token/
OIDC_OP_USER_ENDPOINT=https://auth.exemplo.local/application/o/userinfo/

# n8n Webhook URL (fallback usado quando o painel /configuracoes/webhooks/ nao tiver URL cadastrada)
N8N_WEBHOOK_URL=https://n8n.exemplo.local/webhook
WEBHOOK_PONTO_URL=https://n8n.exemplo.local/webhook/ponto
N8N_WHATSAPP_WEBHOOK_URL=https://n8n.exemplo.local/webhook/whatsapp

# Evolution API (Módulo WhatsApp)
EVOLUTION_API_URL=https://evolution.exemplo.local
EVOLUTION_API_KEY=evolution_api_key_exemplo
EVOLUTION_INSTANCE=instancia_exemplo

# Evo CRM
EVO_CRM_API_URL=https://api-evocrm.exemplo.local
EVO_CRM_API_TOKEN=token_evo_crm_exemplo
EVO_CRM_PIPELINE_ID=uuid_pipeline_exemplo
EVO_CRM_PIPELINE_STAGE_ID=uuid_stage_inicial_exemplo
EVO_CRM_TIMEOUT_SECONDS=4
